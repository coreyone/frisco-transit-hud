{
	"name": "frisco-transit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/mirror-prerendered-pages.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test": "bun run test:unit -- --run && bun run test:e2e",
		"test:unit": "vitest",
		"lint": "biome check package.json svelte.config.js vite.config.ts playwright.config.ts capacitor.config.ts biome.json src/lib/transit src/lib/native src/service-worker.ts src/routes/layout.css src/routes/home.e2e.ts static",
		"format": "biome format --write package.json svelte.config.js vite.config.ts playwright.config.ts capacitor.config.ts biome.json src/lib/transit src/lib/native src/service-worker.ts src/routes/layout.css src/routes/home.e2e.ts static"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.1.18",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@capacitor/app": "^8.1.0",
		"@capacitor/cli": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@capacitor/geolocation": "^8.2.0",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/ios": "^8.3.0",
		"@capacitor/local-notifications": "^8.0.2",
		"@capacitor/network": "^8.0.1",
		"@capacitor/push-notifications": "^8.0.3",
		"@chenglou/pretext": "^0.0.3",
		"lucide-svelte": "^1.0.1",
		"maplibre-gl": "^5.21.1"
	}
}
